{
  "name": "cf-market-agent",
  "main": "index.ts",
  "compatibility_date": "2025-04-01",
  "compatibility_flags": ["nodejs_compat"],

  "ai": {
    "binding": "AI"
  },

  "durable_objects": {
    "bindings": [
      {
        "name": "MARKET_AGENT",
        "class_name": "MarketAgent"
      }
    ]
  },

  "migrations": [
    {
      "tag": "v1",
      "new_sqlite_classes": ["MarketAgent"]
    }
  ],

  "kv_namespaces": [
    {
      "binding": "SESSIONS",
      "id": "f07fad41f8284bd18f0022e4aee4db24"
    }
  ],

  "assets": {
    "directory": "./public",
    "binding": "ASSETS",
    "not_found_handling": "single-page-application"
  }
}
